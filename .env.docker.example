# Copy these into .env when running via Laravel Sail
APP_URL=http://localhost:8080
APP_PORT=8080

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=hotel_booking
DB_USERNAME=sail
DB_PASSWORD=password

CACHE_STORE=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CLIENT=predis

FORWARD_DB_PORT=3307
FORWARD_REDIS_PORT=6380

WWWGROUP=1000
WWWUSER=1000
